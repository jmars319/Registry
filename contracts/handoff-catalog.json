{
  "schema": "tenra-suite.handoff-catalog.v1",
  "updatedOn": "2026-05-07",
  "milestoneTag": "suite-integration-2026-05-07",
  "statusVocabulary": [
    {
      "status": "draft",
      "meaning": "Payload or route exists locally but has not been previewed."
    },
    {
      "status": "previewed",
      "meaning": "Payload was built and inspected without delivery."
    },
    {
      "status": "queued",
      "meaning": "Delivery is waiting for an endpoint, retry, or operator action."
    },
    {
      "status": "sent",
      "meaning": "Producer posted or exported the payload successfully."
    },
    {
      "status": "accepted",
      "meaning": "Consumer parsed and retained the payload."
    },
    {
      "status": "rejected",
      "meaning": "Consumer refused the payload for schema, routing, safety, or policy reasons."
    },
    {
      "status": "failed",
      "meaning": "Delivery failed before acceptance or rejection was known."
    },
    {
      "status": "replayed",
      "meaning": "Registry or a producer regenerated a prior payload for another delivery attempt."
    },
    {
      "status": "received",
      "meaning": "Consumer acknowledged receipt back to the source app."
    },
    {
      "status": "dismissed",
      "meaning": "Operator intentionally removed an item from an inbox, queue, or retry list."
    }
  ],
  "standardUiControls": [
    "schema badge",
    "correlation id",
    "preview payload",
    "copy payload",
    "download JSON",
    "send or export",
    "retry failed",
    "dismiss",
    "reset demo state",
    "import history",
    "export history"
  ],
