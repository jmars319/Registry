{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tenra-proxy.shape-preset-request.v1",
  "title": "Proxy preset shape request",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "presetId",
    "draftText",
    "sourceArtifact",
    "traceId"
  ],
  "properties": {
    "presetId": {
      "type": "string"
    },
    "draftText": {
      "type": "string"
    },
    "sourceArtifact": {
      "type": "object"
    },
    "traceId": {
      "type": "string"
    }
  },
  "x-tenra": {
    "ownerApp": "proxy",
    "producerApp": "source apps",
    "consumerApps": [
      "proxy"
    ],
    "fixture": "tenra Proxy/fixtures/handoffs/shape-preset-scout-outreach.json",
    "correlationFields": [
      "traceId"
    ],
    "standardControls": [
      "correlation id",
      "preview payload",
      "preset import/export",
      "history"
    ]
  }
}
