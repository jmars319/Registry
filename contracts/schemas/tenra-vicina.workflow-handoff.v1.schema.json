{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tenra-vicina.workflow-handoff.v1",
  "title": "Vicina workflow handoff",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "exportedAtMs",
    "sourceApp",
    "workflow",
    "targetApps",
    "signal",
    "operatorNote"
  ],
  "properties": {
    "schema": {
      "const": "tenra-vicina.workflow-handoff.v1",
      "type": "string"
    },
    "exportedAtMs": {
      "type": "number"
    },
    "sourceApp": {
      "type": "string"
    },
    "workflow": {
      "type": "string"
    },
    "targetApps": {
      "type": "array"
    },
    "signal": {
      "type": "object"
    },
    "operatorNote": {
      "type": "string"
    }
  },
  "x-tenra": {
    "ownerApp": "vicina",
    "producerApp": "vicina",
    "consumerApps": [
      "assembly",
      "guardrail",
      "sentinel",
      "proxy"
    ],
    "fixture": "Vicina by tenra/fixtures/handoffs/workflow-handoff.json",
    "correlationFields": [
      "workflow"
    ],
    "standardControls": [
      "schema badge",
      "endpoint health",
      "workflow timeline",
      "preview payload",
      "history"
    ]
  }
}
