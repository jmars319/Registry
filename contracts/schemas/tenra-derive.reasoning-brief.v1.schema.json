{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tenra-derive.reasoning-brief.v1",
  "title": "Derive reasoning brief",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "exportedAt",
    "sourceApp",
    "question",
    "answer",
    "handoff"
  ],
  "properties": {
    "schema": {
      "const": "tenra-derive.reasoning-brief.v1",
      "type": "string"
    },
    "exportedAt": {
      "type": "string"
    },
    "sourceApp": {
      "type": "string"
    },
    "question": {
      "type": "object"
    },
    "answer": {
      "type": "object"
    },
    "handoff": {
      "type": "object"
    }
  },
  "x-tenra": {
    "ownerApp": "derive",
    "producerApp": "derive",
    "consumerApps": [
      "assembly",
      "guardrail",
      "sentinel",
      "proxy"
    ],
    "fixture": "tenra Derive/fixtures/handoffs/reasoning-brief.json",
    "correlationFields": [
      "handoff.briefId"
    ],
    "standardControls": [
      "schema badge",
      "preview payload",
      "brief comparison",
      "history"
    ]
  }
